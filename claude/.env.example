# KilnFlow Ops - local environment configuration
# Copy to .env in packages/backend if you need to override defaults.

# Backend port
PORT=4000

# Frontend port (vite dev server)
VITE_PORT=5173

# Path to SQLite db file (relative to packages/backend)
DATABASE_FILE=./data/kilnflow.sqlite

# CORS origin for the API (frontend dev URL)
CORS_ORIGIN=http://localhost:5173
